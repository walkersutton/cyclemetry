{
  "name": "cyclemetry",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'cd .. && app/node_modules/.bin/tauri dev'",
    "build": "sh -c 'cd .. && app/node_modules/.bin/tauri build'",
    "vite": "vite",
    "vite-build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "sync-version": "node -e \"const fs=require('fs');const v=fs.readFileSync('../src-tauri/Cargo.toml','utf8').match(/^version = \\\"(.+)\\\"/m)[1];const p=JSON.parse(fs.readFileSync('package.json','utf8'));p.version=v;fs.writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "release": "VERSION=$(grep '^version' ../src-tauri/Cargo.toml | head -1 | sed 's/version = \"\\(.*\\)\"/\\1/') && pnpm sync-version && git -C .. add src-tauri/Cargo.toml app/package.json && git -C .. commit -m \"v$VERSION\" && git -C .. tag v$VERSION && git -C .. push origin main && git -C .. push origin v$VERSION"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@tauri-apps/api": "^2.9.1",
    "@tauri-apps/plugin-dialog": "^2.5.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "clsx": "^2.1.1",
    "lucide-svelte": "^0.511.0",
    "svelte": "^5.34.6",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.9.6",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-svelte": "^3.9.0",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vite": "^7.2.4"
  },
  "packageManager": "pnpm@10.25.0"
}
